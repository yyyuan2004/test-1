# === LLM API Keys (fill in to enable online mode) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Model Settings ===
# Options: openai, anthropic, local
DEFAULT_LLM_BACKEND=openai
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Local model path (relative to project root or absolute)
LOCAL_MODEL_PATH=data/models/your-model.gguf
LOCAL_MODEL_CONTEXT_LENGTH=4096
LOCAL_MODEL_GPU_LAYERS=0

# === Embedding ===
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Server ===
HOST=127.0.0.1
PORT=8765

# === RAG ===
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
