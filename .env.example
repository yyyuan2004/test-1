# === LLM API Keys ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

QWEN_API_KEY=
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# === Default Backend ===
# Options: openai, anthropic, deepseek, qwen, zhipu, local
DEFAULT_LLM_BACKEND=openai

# === Local Model ===
LOCAL_MODEL_PATH=data/models/your-model.gguf
LOCAL_MODEL_CONTEXT_LENGTH=4096
LOCAL_MODEL_GPU_LAYERS=0

# === Embedding ===
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Server ===
HOST=127.0.0.1
PORT=8765

# === RAG ===
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# === Memory ===
MEMORY_SHORT_TERM_LIMIT=10
MEMORY_SUMMARY_THRESHOLD=20
MEMORY_MAX_SUMMARIES=5

# === Humanizer ===
HUMANIZE_ENABLED=true
HUMANIZE_TYPO_RATE=0.02
HUMANIZE_FILLER_RATE=0.15

# === Privacy ===
PII_MASKING_ENABLED=true
